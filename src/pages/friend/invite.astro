---
import InviteLanding from '@/components/react/InviteLanding';
import SiteFooter from '@/components/sections/SiteFooter.astro';
import SiteNav from '@/components/sections/SiteNav.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Invitation Bicount | Rejoindre l'application"
  description="Ouvre cette invitation dans Bicount pour rejoindre un partage de dépenses, puis télécharge l'application si besoin."
  canonicalPath="/friend/invite"
  robots="noindex, nofollow"
>
  <SiteNav />
  <main>
    <InviteLanding client:load />
  </main>
  <SiteFooter />
</BaseLayout>
