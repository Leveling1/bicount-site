---
import SvgIcon from '@/components/common/SvgIcon.astro';
---

<footer class="footer" role="contentinfo">
  <div class="wrap">
    <div class="footer__inner">
      <a href="/" class="nav__logo" style="gap:8px;" aria-label="Bicount accueil">
        <div class="logo-mark footer-logo" aria-hidden="true">
          <SvgIcon name="logo" size={14} stroke="#BCD367" />
        </div>
        <span class="logo-text footer-text">Bicount</span>
      </a>
      <p class="body">© 2026 Bicount · Kinshasa, République Démocratique du Congo</p>
      <p class="body">Application en cours de développement</p>
    </div>
  </div>
</footer>
