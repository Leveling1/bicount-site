---
import SectionHeader from '@/components/common/SectionHeader.astro';
import SvgIcon from '@/components/common/SvgIcon.astro';

interface Card {
  icon: 'alert' | 'clock' | 'coin' | 'cross' | 'list' | 'trend-rise';
  title: string;
  body: string;
  wide?: boolean;
  variant?: 'bars' | 'tags';
}

interface Props {
  id: string;
  eyebrow: string;
  title: string;
  lead: string;
  alt?: boolean;
  cards: Card[];
}

const { id, eyebrow, title, lead, alt = false, cards } = Astro.props;
---

<section class:list={['sec', alt && 'sec-alt']} aria-labelledby={id}>
  <div class="wrap">
    <SectionHeader id={id} eyebrow={eyebrow} title={title} lead={lead} />
    <div class="bento">
      {cards.map((card, index) => (
        <article class:list={['b-card rv', card.wide && 'b-wide', `d${(index % 3) + 1}`]}>
          <div class="b-icon" aria-hidden="true">
            <SvgIcon name={card.icon} size={20} stroke="#69773A" />
          </div>
          <h3>{card.title}</h3>
          <p class="body" set:html={card.body} />
          {card.variant === 'bars' && (
            <div class="b-inner" aria-hidden="true">
              <div class="b-mini-bar" style="height:38%"></div>
              <div class="b-mini-bar mid" style="height:62%"></div>
              <div class="b-mini-bar" style="height:44%"></div>
              <div class="b-mini-bar mid" style="height:78%"></div>
              <div class="b-mini-bar active" style="height:100%"></div>
              <div class="b-mini-bar" style="height:55%"></div>
              <div class="b-mini-bar" style="height:32%"></div>
            </div>
          )}
          {card.variant === 'tags' && (
            <div class="b-cats" aria-hidden="true">
              <span class="b-cat active">Nourriture</span>
              <span class="b-cat">Transport</span>
              <span class="b-cat active">Data</span>
              <span class="b-cat">Famille</span>
              <span class="b-cat">Business</span>
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
