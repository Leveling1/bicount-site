---
import ClientBehaviors from '@/components/react/ClientBehaviors';
import { siteMeta } from '@/config/site';
import '@/styles/global.css';
import '@/styles/hero.css';
import '@/styles/bento.css';
import '@/styles/pro.css';
import '@/styles/principles.css';
import '@/styles/cta.css';
import '@/styles/invite.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  robots?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  canonicalPath = '/',
  robots = 'index, follow',
  schema
} = Astro.props;
const canonicalUrl = new URL(canonicalPath, siteMeta.url).toString();
const schemaList = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="theme-color" content="#FFFFFF" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Bicount" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={siteMeta.image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Bicount, application de gestion de dépenses et budget personnel" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={siteMeta.image} />
    <link rel="icon" href="/images/logo-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    {schemaList.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body>
    <slot />
    <ClientBehaviors client:load />
  </body>
</html>
